# ============================================
# GHOSTTY CONFIG
# ============================================
# Symlinked: ~/.config/ghostty/config -> this file
# ============================================

# --------------------------------------------
# THEME
# --------------------------------------------

theme = vscode-light.conf

# --------------------------------------------
# FONT
# --------------------------------------------

font-family = MesloLGS Nerd Font Mono
font-size = 14

# --------------------------------------------
# WINDOW
# --------------------------------------------

window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
scrollback-limit = 100000

# --------------------------------------------
# BEHAVIOR
# --------------------------------------------

mouse-hide-while-typing = true
copy-on-select = clipboard

# Send Option as Alt so Meta keybindings work in tmux
macos-option-as-alt = true

# Forward Alt-Backspace to tmux/pi instead of handling it locally
keybind = alt+backspace=text:\x1b\x7f

shell-integration = detect
